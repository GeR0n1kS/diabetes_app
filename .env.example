# Diabetes Risk Prediction System - Environment Variables

# Application Settings
APP_ENV=development
DEBUG=False
LOG_LEVEL=INFO

# GUI Settings
GUI_LANGUAGE=en

# Database Settings
DB_TYPE=sqlite  # sqlite or postgresql

# PostgreSQL Settings (if DB_TYPE=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=diabetes_db
DB_USER=diabetes_user
DB_PASSWORD=change_this_password

# Security Settings
ENCRYPTION_ENABLED=True
AUTH_ENABLED=False
JWT_SECRET=change_this_secret_in_production
ALLOWED_IPS=*

# API Settings (optional)
API_ENABLED=False
API_HOST=127.0.0.1
API_PORT=5000
API_KEY=change_this_api_key